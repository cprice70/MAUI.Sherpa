@code {
    private string activeTab = "general";

    // General
    private string profileName = "";
    private string profileDescription = "";
    private string selectedPublisherId = "";
    private string selectedRepoId = "";
    private string selectedRepoFullName = "";
    private string repoSearch = "";
    private bool loadingRepos;
    private string? existingProfileId;

    // Apple
    private List<AppleConfigVM> appleConfigs = new();
    private List<AppleCertificate> certificates = new();
    private List<AppleProfile> profiles = new();

    // Android
    private List<AndroidConfigVM> androidConfigs = new();
    private List<AndroidKeystore> keystores = new();

    // Secrets
    private List<SecretMappingVM> secretMappings = new();
    private List<ManagedSecret> managedSecrets = new();
    private bool showSecretPicker;
    private string secretSearch = "";

    // Publishers
    private List<SecretsPublisherConfig> publishers = new();
    private List<PublisherRepository> repos = new();

    private IEnumerable<PublisherRepository> filteredRepos =>
        string.IsNullOrWhiteSpace(repoSearch)
            ? repos
            : repos.Where(r => r.FullName.Contains(repoSearch, StringComparison.OrdinalIgnoreCase)
                || (r.Description?.Contains(repoSearch, StringComparison.OrdinalIgnoreCase) ?? false));

    private IEnumerable<ManagedSecret> filteredManagedSecrets
    {
        get
        {
            var existingKeys = secretMappings.Select(m => m.SourceKey).ToHashSet();
            var available = managedSecrets.Where(s => !existingKeys.Contains(s.Key));
            return string.IsNullOrWhiteSpace(secretSearch)
                ? available
                : available.Where(s => s.Key.Contains(secretSearch, StringComparison.OrdinalIgnoreCase)
                    || (s.Description?.Contains(secretSearch, StringComparison.OrdinalIgnoreCase) ?? false));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var bridge = BridgeHolder.Current;
        if (bridge is null) return;

        bridge.SubmitRequested += OnSubmitRequested;

        // Load existing profile if editing
        if (bridge.Parameters.TryGetValue("Profile", out var profileObj) && profileObj is PublishProfile existing)
        {
            existingProfileId = existing.Id;
            profileName = existing.Name;
            profileDescription = existing.Description ?? "";
            selectedPublisherId = existing.PublisherId ?? "";
            selectedRepoId = existing.RepositoryId ?? "";
            selectedRepoFullName = existing.RepositoryFullName ?? "";

            appleConfigs = existing.AppleConfigs.Select(a => new AppleConfigVM
            {
                Label = a.Label,
                CertificateSerialNumber = a.CertificateSerialNumber,
                InstallerCertSerialNumber = a.InstallerCertSerialNumber,
                ProfileId = a.ProfileId,
                ProfileUuid = a.ProfileUuid,
                IncludeNotarization = a.IncludeNotarization,
                KeyMappings = a.KeyMappings.ToDictionary(k => k.Key, k => k.Value.ToList())
            }).ToList();

            androidConfigs = existing.AndroidConfigs.Select(a => new AndroidConfigVM
            {
                Label = a.Label,
                KeystoreId = a.KeystoreId,
                KeyMappings = a.KeyMappings.ToDictionary(k => k.Key, k => k.Value.ToList())
            }).ToList();

            secretMappings = existing.SecretMappings.Select(s => new SecretMappingVM
            {
                SourceKey = s.SourceKey,
                DestinationKeys = s.DestinationKeys.ToList()
            }).ToList();
        }

        ValidateForm();

        // Load data in parallel
        try
        {
            var publishersTask = PublisherService.GetPublishersAsync();
            var keystoresTask = KeystoreService.ListKeystoresAsync();
            var secretsTask = ManagedSecrets.ListAsync();

            publishers = (await publishersTask).ToList();
            keystores = (await keystoresTask).ToList();
            managedSecrets = (await secretsTask).ToList();

            // Load Apple data if an identity is available
            var identities = await AppleIdentityService.GetIdentitiesAsync();
            if (identities.Any())
            {
                var id = identities.First().Id;
                try
                {
                    var certResult = await Mediator.Request(new GetCertificatesRequest(id));
                    certificates = certResult.Result?.ToList() ?? new();
                    var profileResult = await Mediator.Request(new GetProfilesRequest(id));
                    profiles = profileResult.Result?.ToList() ?? new();
                }
                catch { }
            }

            // Load repos if publisher is selected
            if (!string.IsNullOrEmpty(selectedPublisherId))
                await LoadReposAsync();
        }
        catch { }

        StateHasChanged();
    }

    private async Task LoadReposAsync()
    {
        if (string.IsNullOrEmpty(selectedPublisherId)) return;
        loadingRepos = true;
        StateHasChanged();

        try
        {
            repos = (await PublisherService.ListRepositoriesAsync(selectedPublisherId)).ToList();
        }
        catch { repos = new(); }

        loadingRepos = false;
        StateHasChanged();
    }

    private void ValidateForm()
    {
        var bridge = BridgeHolder.Current;
        bridge?.SetValid(!string.IsNullOrWhiteSpace(profileName));
    }

    private Task OnSubmitRequested()
    {
        var bridge = BridgeHolder.Current;
        if (bridge is null) return Task.CompletedTask;

        var profile = new PublishProfile(
            Id: existingProfileId ?? Guid.NewGuid().ToString(),
            Name: profileName.Trim(),
            Description: string.IsNullOrWhiteSpace(profileDescription) ? null : profileDescription.Trim(),
            PublisherId: string.IsNullOrEmpty(selectedPublisherId) ? null : selectedPublisherId,
            RepositoryId: string.IsNullOrEmpty(selectedRepoId) ? null : selectedRepoId,
            RepositoryFullName: string.IsNullOrEmpty(selectedRepoFullName) ? null : selectedRepoFullName,
            AppleConfigs: appleConfigs.Select(a => new PublishProfileAppleConfig(
                a.Label,
                a.CertificateSerialNumber,
                a.InstallerCertSerialNumber,
                a.ProfileId,
                a.ProfileUuid,
                a.IncludeNotarization,
                a.KeyMappings.ToDictionary(k => k.Key, k => k.Value.ToList())
            )).ToList(),
            AndroidConfigs: androidConfigs.Select(a => new PublishProfileAndroidConfig(
                a.Label,
                a.KeystoreId,
                a.KeyMappings.ToDictionary(k => k.Key, k => k.Value.ToList())
            )).ToList(),
            SecretMappings: secretMappings.Select(s => new PublishProfileSecretMapping(
                s.SourceKey,
                s.DestinationKeys.ToList()
            )).ToList(),
            CreatedAt: existingProfileId is not null
                ? (BridgeHolder.Current?.Parameters.TryGetValue("Profile", out var p) == true && p is PublishProfile ep ? ep.CreatedAt : DateTime.UtcNow)
                : DateTime.UtcNow,
            UpdatedAt: DateTime.UtcNow
        );

        bridge.Result = profile;
        return Task.CompletedTask;
    }

    // Apple helpers
    private void AddAppleConfig()
    {
        appleConfigs.Add(new AppleConfigVM { Label = "AdHoc" });
    }

    private bool IsSigningCertType(string certType)
        => certType.Contains("DISTRIBUTION", StringComparison.OrdinalIgnoreCase)
           || certType.Contains("DEVELOPMENT", StringComparison.OrdinalIgnoreCase)
           || certType.Contains("DEVELOPER_ID", StringComparison.OrdinalIgnoreCase);

    // Android helpers
    private void AddAndroidConfig()
    {
        androidConfigs.Add(new AndroidConfigVM { Label = "PlayStore" });
    }

    // Secrets helpers
    private void AddSecretMapping(string sourceKey)
    {
        if (secretMappings.Any(m => m.SourceKey == sourceKey)) return;
        secretMappings.Add(new SecretMappingVM
        {
            SourceKey = sourceKey,
            DestinationKeys = new List<string> { sourceKey }
        });
        showSecretPicker = false;
    }

    // Key mapping helpers
    private void AddDestination(Dictionary<string, List<string>> mappings, string defaultKey)
    {
        if (!mappings.ContainsKey(defaultKey))
            mappings[defaultKey] = new List<string> { defaultKey };
        mappings[defaultKey].Add(defaultKey + "_" + (mappings[defaultKey].Count + 1));
    }

    private void RemoveDestination(Dictionary<string, List<string>> mappings, string defaultKey, string dest)
    {
        if (mappings.TryGetValue(defaultKey, out var list))
        {
            list.Remove(dest);
            if (list.Count == 0)
                mappings.Remove(defaultKey);
        }
    }

    private void UpdateDestination(Dictionary<string, List<string>> mappings, string defaultKey, string oldDest, string newDest)
    {
        if (mappings.TryGetValue(defaultKey, out var list))
        {
            var idx = list.IndexOf(oldDest);
            if (idx >= 0 && !string.IsNullOrWhiteSpace(newDest))
                list[idx] = newDest;
        }
    }

    public void Dispose()
    {
        var bridge = BridgeHolder.Current;
        if (bridge is not null)
            bridge.SubmitRequested -= OnSubmitRequested;
    }

    // View models for mutable editing
    private class AppleConfigVM
    {
        public string Label { get; set; } = "";
        public string? CertificateSerialNumber { get; set; }
        public string? InstallerCertSerialNumber { get; set; }
        public string? ProfileId { get; set; }
        public string? ProfileUuid { get; set; }
        public bool IncludeNotarization { get; set; }
        public Dictionary<string, List<string>> KeyMappings { get; set; } = new();

        public bool ShowCertPicker => CertificateSerialNumber is null;
        public bool ShowInstallerPicker => InstallerCertSerialNumber is null;
        public bool ShowProfilePicker => ProfileId is null;

        public bool HasAnyItems => !string.IsNullOrEmpty(CertificateSerialNumber)
            || !string.IsNullOrEmpty(InstallerCertSerialNumber)
            || !string.IsNullOrEmpty(ProfileId)
            || IncludeNotarization;

        public List<string> GetDefaultKeys()
        {
            var keys = new List<string>();
            var label = Label.ToUpperInvariant().Replace(' ', '_').Replace('-', '_');
            if (!string.IsNullOrEmpty(CertificateSerialNumber))
            {
                keys.Add($"APPLE_{label}_CERTIFICATE_P12");
                keys.Add($"APPLE_{label}_CERTIFICATE_PASSWORD");
            }
            if (!string.IsNullOrEmpty(InstallerCertSerialNumber))
            {
                keys.Add($"APPLE_{label}_INSTALLER_CERTIFICATE_P12");
                keys.Add($"APPLE_{label}_INSTALLER_CERTIFICATE_PASSWORD");
            }
            if (!string.IsNullOrEmpty(ProfileId))
                keys.Add($"APPLE_{label}_PROVISIONING_PROFILE");
            if (IncludeNotarization)
            {
                keys.Add("APPLE_NOTARIZATION_KEY_ID");
                keys.Add("APPLE_NOTARIZATION_ISSUER_ID");
                keys.Add("APPLE_NOTARIZATION_KEY_P8");
            }

            // Ensure all keys exist in mappings with default
            foreach (var key in keys)
            {
                if (!KeyMappings.ContainsKey(key))
                    KeyMappings[key] = new List<string> { key };
            }

            // Remove stale mappings
            foreach (var k in KeyMappings.Keys.ToList())
            {
                if (!keys.Contains(k))
                    KeyMappings.Remove(k);
            }

            return keys;
        }
    }

    private class AndroidConfigVM
    {
        public string Label { get; set; } = "";
        public string? KeystoreId { get; set; }
        public Dictionary<string, List<string>> KeyMappings { get; set; } = new();

        public bool ShowKeystorePicker => KeystoreId is null;

        public bool HasAnyItems => !string.IsNullOrEmpty(KeystoreId);

        public List<string> GetDefaultKeys()
        {
            var keys = new List<string>();
            var label = Label.ToUpperInvariant().Replace(' ', '_').Replace('-', '_');
            if (!string.IsNullOrEmpty(KeystoreId))
            {
                keys.Add($"ANDROID_{label}_KEYSTORE");
                keys.Add($"ANDROID_{label}_KEYSTORE_PASSWORD");
                keys.Add($"ANDROID_{label}_KEY_ALIAS");
                keys.Add($"ANDROID_{label}_KEY_PASSWORD");
            }

            foreach (var key in keys)
            {
                if (!KeyMappings.ContainsKey(key))
                    KeyMappings[key] = new List<string> { key };
            }

            foreach (var k in KeyMappings.Keys.ToList())
            {
                if (!keys.Contains(k))
                    KeyMappings.Remove(k);
            }

            return keys;
        }
    }

    private class SecretMappingVM
    {
        public string SourceKey { get; set; } = "";
        public List<string> DestinationKeys { get; set; } = new();
    }
}
