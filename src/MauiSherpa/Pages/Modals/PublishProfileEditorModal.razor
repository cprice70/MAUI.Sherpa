@code {
    private string activeTab = "general";

    // General
    private string profileName = "";
    private string profileDescription = "";
    private string? existingProfileId;
    private List<PublishProfilePublisher> profilePublishers = new();
    private bool isSaving;

    // Apple
    private List<AppleConfigVM> appleConfigs = new();
    private List<AppleIdentity> appleIdentities = new();

    // Android
    private List<AndroidConfigVM> androidConfigs = new();
    private List<AndroidKeystore> keystores = new();

    // Secrets
    private List<SecretMappingVM> secretMappings = new();
    private List<ManagedSecret> managedSecrets = new();

    // Publishers
    private List<SecretsPublisherConfig> publishers = new();
    private bool demoMode;

    protected override async Task OnInitializedAsync()
    {
        var bridge = BridgeHolder.Current;
        if (bridge is null) return;

        bridge.SubmitRequested += OnSubmitRequested;

        demoMode = (await SettingsService.GetSettingsAsync()).Preferences.DemoMode;

        // Load existing profile if editing
        if (bridge.Parameters.TryGetValue("Profile", out var profileObj) && profileObj is PublishProfile existing)
        {
            existingProfileId = existing.Id;
            profileName = existing.Name;
            profileDescription = existing.Description ?? "";

            // Load publishers list (new format)
            profilePublishers = existing.Publishers?.ToList() ?? new();
            // Migrate legacy single publisher if present
            if (!profilePublishers.Any() && !string.IsNullOrEmpty(existing.PublisherId) && !string.IsNullOrEmpty(existing.RepositoryId))
            {
                var legacyPub = publishers.FirstOrDefault(p => p.Id == existing.PublisherId);
                if (legacyPub is not null)
                {
                    profilePublishers.Add(new PublishProfilePublisher(
                        legacyPub.Id, legacyPub.Name, legacyPub.ProviderId,
                        existing.RepositoryId, existing.RepositoryFullName ?? existing.RepositoryId));
                }
            }

            appleConfigs = existing.AppleConfigs.Select(a => new AppleConfigVM
            {
                Label = a.Label,
                IdentityId = a.IdentityId,
                Platform = a.Platform,
                DistributionType = a.DistributionType,
                CertificateSerialNumber = a.CertificateSerialNumber,
                InstallerCertSerialNumber = a.InstallerCertSerialNumber,
                ProfileId = a.ProfileId,
                ProfileUuid = a.ProfileUuid,
                IncludeNotarization = a.IncludeNotarization,
                NotarizationAppleIdSecretKey = a.NotarizationAppleIdSecretKey,
                NotarizationPasswordSecretKey = a.NotarizationPasswordSecretKey,
                NotarizationTeamIdSecretKey = a.NotarizationTeamIdSecretKey,
                NotarizationAppleIdManualValue = a.NotarizationAppleIdManualValue,
                NotarizationPasswordManualValue = a.NotarizationPasswordManualValue,
                NotarizationTeamIdManualValue = a.NotarizationTeamIdManualValue,
                NotarizationAppleIdUseManual = !string.IsNullOrEmpty(a.NotarizationAppleIdManualValue),
                NotarizationPasswordUseManual = !string.IsNullOrEmpty(a.NotarizationPasswordManualValue),
                NotarizationTeamIdUseManual = !string.IsNullOrEmpty(a.NotarizationTeamIdManualValue),
                KeyMappings = a.KeyMappings.ToDictionary(k => k.Key, k => k.Value.ToList()),
                IsComplete = true
            }).ToList();

            androidConfigs = existing.AndroidConfigs.Select(a => new AndroidConfigVM
            {
                Label = a.Label,
                KeystoreId = a.KeystoreId,
                KeyMappings = a.KeyMappings.ToDictionary(k => k.Key, k => k.Value.ToList())
            }).ToList();

            secretMappings = existing.SecretMappings.Select(s => new SecretMappingVM
            {
                SourceKey = s.SourceKey,
                DestinationKeys = s.DestinationKeys.ToList()
            }).ToList();
        }

        ValidateForm();

        // Load data in parallel
        try
        {
            var publishersTask = PublisherService.GetPublishersAsync();
            var keystoresTask = KeystoreService.ListKeystoresAsync();
            var secretsTask = ManagedSecrets.ListAsync();

            publishers = (await publishersTask).ToList();
            keystores = (await keystoresTask).ToList();
            managedSecrets = (await secretsTask).ToList();

            // Load Apple identities (cert/profile loading deferred to wizard identity selection)
            try { appleIdentities = (await AppleIdentityService.GetIdentitiesAsync()).ToList(); }
            catch { }

        }
        catch { }

        StateHasChanged();
    }

    private async Task OpenPublisherModal()
    {
        var page = new AddPublisherPage(BridgeHolder, publishers, profilePublishers);
        var result = await FormModal.ShowAsync(page);
        if (result != null)
        {
            if (!profilePublishers.Any(p => p.PublisherId == result.PublisherId && p.RepositoryId == result.RepositoryId))
                profilePublishers.Add(result);
        }
    }

    private string GetProviderIcon(string providerId) => providerId switch
    {
        "github" => "fa-brands fa-github",
        "gitlab" => "fa-brands fa-gitlab",
        "gitea" => "fa-solid fa-mug-hot",
        "azuredevops" => "fa-brands fa-microsoft",
        _ => "fa-solid fa-cloud"
    };

    private void ValidateForm()
    {
        var bridge = BridgeHolder.Current;
        // Disable native Save/Cancel when wizard popup is open
        bridge?.SetValid(!string.IsNullOrWhiteSpace(profileName));
    }

    private async Task OnSubmitRequested()
    {
        var bridge = BridgeHolder.Current;
        if (bridge is null) return;

        isSaving = true;
        bridge.SetValid(false); // Disable buttons while saving
        await InvokeAsync(StateHasChanged);

        var profile = new PublishProfile(
            Id: existingProfileId ?? Guid.NewGuid().ToString(),
            Name: profileName.Trim(),
            Description: string.IsNullOrWhiteSpace(profileDescription) ? null : profileDescription.Trim(),
            PublisherId: profilePublishers.FirstOrDefault()?.PublisherId,
            RepositoryId: profilePublishers.FirstOrDefault()?.RepositoryId,
            RepositoryFullName: profilePublishers.FirstOrDefault()?.RepositoryFullName,
            AppleConfigs: appleConfigs.Select(a => new PublishProfileAppleConfig(
                a.Label,
                a.IdentityId,
                a.Platform,
                a.DistributionType,
                a.CertificateSerialNumber,
                a.InstallerCertSerialNumber,
                a.ProfileId,
                a.ProfileUuid,
                a.IncludeNotarization,
                a.NotarizationAppleIdUseManual ? null : a.NotarizationAppleIdSecretKey,
                a.NotarizationPasswordUseManual ? null : a.NotarizationPasswordSecretKey,
                a.NotarizationTeamIdUseManual ? null : a.NotarizationTeamIdSecretKey,
                a.NotarizationAppleIdUseManual ? a.NotarizationAppleIdManualValue : null,
                a.NotarizationPasswordUseManual ? a.NotarizationPasswordManualValue : null,
                a.NotarizationTeamIdUseManual ? a.NotarizationTeamIdManualValue : null,
                a.KeyMappings.ToDictionary(k => k.Key, k => k.Value.ToList())
            )).ToList(),
            AndroidConfigs: androidConfigs.Select(a => new PublishProfileAndroidConfig(
                a.Label,
                a.KeystoreId,
                a.KeyMappings.ToDictionary(k => k.Key, k => k.Value.ToList())
            )).ToList(),
            SecretMappings: secretMappings.Select(s => new PublishProfileSecretMapping(
                s.SourceKey,
                s.DestinationKeys.ToList()
            )).ToList(),
            CreatedAt: existingProfileId is not null
                ? (BridgeHolder.Current?.Parameters.TryGetValue("Profile", out var p) == true && p is PublishProfile ep ? ep.CreatedAt : DateTime.UtcNow)
                : DateTime.UtcNow,
            UpdatedAt: DateTime.UtcNow
        ) { Publishers = profilePublishers.ToList() };

        try
        {
            await ProfileService.SaveProfileAsync(profile);
        }
        catch
        {
            isSaving = false;
            bridge.SetValid(true);
            await InvokeAsync(StateHasChanged);
            return;
        }

        bridge.Result = profile;
    }

    // Apple wizard helpers
    private async Task OpenAppleConfigWizard()
    {
        var page = new AppleConfigWizardPage(BridgeHolder, appleIdentities, managedSecrets);
        var result = await FormModal.ShowAsync(page);
        if (result != null && !appleConfigs.Contains(result))
            appleConfigs.Add(result);
        ValidateForm();
    }

    private async Task EditAppleConfigModal(AppleConfigVM config)
    {
        var page = new AppleConfigWizardPage(BridgeHolder, appleIdentities, managedSecrets, config);
        var result = await FormModal.ShowAsync(page);
        // The config is mutated in-place by the wizard; if cancelled, original state is already changed
        // but if result is non-null, mark it complete
        if (result != null)
        {
            if (!appleConfigs.Contains(result))
                appleConfigs.Add(result);
        }
        ValidateForm();
    }

    // Android helpers
    private void AddAndroidConfig()
    {
        androidConfigs.Add(new AndroidConfigVM { Label = "PlayStore" });
    }

    // Secrets helpers
    private async Task OpenSecretPicker()
    {
        var existingKeys = secretMappings.Select(m => m.SourceKey).ToList();
        var page = new SecretPickerPage(BridgeHolder, managedSecrets, existingKeys);
        var selectedKey = await FormModal.ShowAsync(page);
        if (!string.IsNullOrEmpty(selectedKey))
            AddSecretMapping(selectedKey);
    }

    private void AddSecretMapping(string sourceKey)
    {
        if (secretMappings.Any(m => m.SourceKey == sourceKey)) return;
        secretMappings.Add(new SecretMappingVM
        {
            SourceKey = sourceKey,
            DestinationKeys = new List<string> { sourceKey }
        });
    }

    // Key mapping helpers
    private void AddDestination(Dictionary<string, List<string>> mappings, string defaultKey)
    {
        if (!mappings.ContainsKey(defaultKey))
            mappings[defaultKey] = new List<string> { defaultKey };
        mappings[defaultKey].Add(defaultKey + "_" + (mappings[defaultKey].Count + 1));
    }

    private void RemoveDestination(Dictionary<string, List<string>> mappings, string defaultKey, string dest)
    {
        if (mappings.TryGetValue(defaultKey, out var list))
        {
            list.Remove(dest);
            if (list.Count == 0)
                mappings.Remove(defaultKey);
        }
    }

    private void UpdateDestination(Dictionary<string, List<string>> mappings, string defaultKey, string oldDest, string newDest)
    {
        if (mappings.TryGetValue(defaultKey, out var list))
        {
            var idx = list.IndexOf(oldDest);
            if (idx >= 0 && !string.IsNullOrWhiteSpace(newDest))
                list[idx] = newDest;
        }
    }

    public void Dispose()
    {
        var bridge = BridgeHolder.Current;
        if (bridge is not null)
            bridge.SubmitRequested -= OnSubmitRequested;
    }

    private class AndroidConfigVM
    {
        public string Label { get; set; } = "";
        public string? KeystoreId { get; set; }
        public Dictionary<string, List<string>> KeyMappings { get; set; } = new();

        public bool ShowKeystorePicker => KeystoreId is null;

        public bool HasAnyItems => !string.IsNullOrEmpty(KeystoreId);

        public List<string> GetDefaultKeys()
        {
            var keys = new List<string>();
            var label = Label.ToUpperInvariant().Replace(' ', '_').Replace('-', '_');
            if (!string.IsNullOrEmpty(KeystoreId))
            {
                keys.Add($"ANDROID_{label}_KEYSTORE");
                keys.Add($"ANDROID_{label}_KEYSTORE_PASSWORD");
                keys.Add($"ANDROID_{label}_KEY_ALIAS");
                keys.Add($"ANDROID_{label}_KEY_PASSWORD");
            }

            foreach (var key in keys)
            {
                if (!KeyMappings.ContainsKey(key))
                    KeyMappings[key] = new List<string> { key };
            }

            foreach (var k in KeyMappings.Keys.ToList())
            {
                if (!keys.Contains(k))
                    KeyMappings.Remove(k);
            }

            return keys;
        }
    }

    private class SecretMappingVM
    {
        public string SourceKey { get; set; } = "";
        public List<string> DestinationKeys { get; set; } = new();
    }
}
