@page "/modal/publish-secrets"
@using MauiSherpa.Core.Interfaces
@using MauiSherpa.Pages.Forms
@inject HybridFormBridgeHolder BridgeHolder
@inject ISecretsPublisherService PublisherService
@inject ISecretsPublisherFactory PublisherFactory
@inject ILoggingService Logger
@implements IDisposable

<div class="step-content">
    @if (step == 1)
    {
        <h3>Select CI/CD Provider</h3>
        <p class="step-description">Choose where to publish your secrets.</p>

        @if (isLoadingPublishers)
        {
            <div class="loading-state">
                <i class="fas fa-spinner fa-spin"></i>
                <span>Loading providers...</span>
            </div>
        }
        else if (publishers.Count == 0)
        {
            <div class="empty-state">
                <i class="fas fa-plug"></i>
                <p>No CI/CD publishers configured.</p>
                <p class="help-text">Add a CI/CD publisher in Settings first.</p>
            </div>
        }
        else
        {
            <div class="provider-selection">
                @foreach (var publisher in publishers)
                {
                    <div class="provider-option @(selectedPublisher?.Id == publisher.Id ? "selected" : "")"
                         @onclick="@(() => SelectPublisher(publisher))">
                        <i class="@GetPublisherIcon(publisher.ProviderId) provider-icon"></i>
                        <div class="provider-info">
                            <span class="provider-name">@publisher.Name</span>
                            <span class="provider-type">@GetPublisherDisplayName(publisher.ProviderId)</span>
                        </div>
                        @if (selectedPublisher?.Id == publisher.Id)
                        {
                            <i class="fas fa-check-circle selected-icon"></i>
                        }
                    </div>
                }
            </div>
        }
    }
    else if (step == 2)
    {
        <h3>Select Repository</h3>
        <p class="step-description">Choose the repository to publish secrets to.</p>

        <div class="search-box">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="Search repositories..."
                   @bind="repoSearchFilter"
                   @bind:event="oninput" />
        </div>

        @if (isLoadingRepos)
        {
            <div class="loading-state">
                <i class="fas fa-spinner fa-spin"></i>
                <span>Loading repositories...</span>
            </div>
        }
        else if (FilteredRepositories.Count == 0)
        {
            <div class="empty-state">
                <i class="fas fa-folder-open"></i>
                <p>No repositories found.</p>
            </div>
        }
        else
        {
            <div class="selection-list">
                @foreach (var repo in FilteredRepositories)
                {
                    <div class="selection-item @(selectedRepository?.Id == repo.Id ? "selected" : "")"
                         @onclick="@(() => SelectRepository(repo))">
                        <i class="fas fa-code-branch" style="margin-top: 2px; color: var(--text-muted);"></i>
                        <div class="item-content">
                            <div class="item-name">@repo.FullName</div>
                            @if (!string.IsNullOrEmpty(repo.Description))
                            {
                                <div class="item-detail">@(repo.Description.Length > 80 ? repo.Description[..80] + "…" : repo.Description)</div>
                            }
                        </div>
                        @if (selectedRepository?.Id == repo.Id)
                        {
                            <i class="fas fa-check-circle" style="color: #8b5cf6;"></i>
                        }
                    </div>
                }
            </div>
        }
    }
    else if (step == 3)
    {
        @if (isPublishing)
        {
            <div class="publishing-progress">
                <i class="fas fa-spinner fa-spin fa-2x"></i>
                <h3>Publishing Secrets...</h3>
                <p>@publishingStatus</p>
            </div>
        }
        else if (publishComplete)
        {
            <div class="publish-success">
                <i class="fas fa-check-circle fa-3x text-success"></i>
                <h3>Secrets Published!</h3>
                <p>@secretsDict.Count secret(s) published to @selectedRepository?.FullName.</p>
            </div>
        }
        else
        {
            <h3>Confirm Publication</h3>
            <p class="step-description">Review and confirm the secrets to be published.</p>

            <div class="publish-summary">
                <div class="summary-item">
                    <span class="summary-label">Provider:</span>
                    <span class="summary-value">
                        <i class="@GetPublisherIcon(selectedPublisher?.ProviderId ?? "")"></i>
                        @selectedPublisher?.Name
                    </span>
                </div>
                <div class="summary-item">
                    <span class="summary-label">Repository:</span>
                    <span class="summary-value">@selectedRepository?.FullName</span>
                </div>
                <div class="summary-item">
                    <span class="summary-label">Secrets:</span>
                    <span class="summary-value">@secretsDict.Count secret(s)</span>
                </div>
            </div>

            <div class="secrets-preview">
                @foreach (var name in secretsDict.Keys)
                {
                    <code class="secret-badge">@name</code>
                }
            </div>

            <div class="warning-box">
                <i class="fas fa-exclamation-triangle"></i>
                <span>Existing secrets with the same names will be overwritten.</span>
            </div>
        }
    }
</div>

<style>
    .step-content {
        display: flex;
        flex-direction: column;
        flex: 1;
        overflow: hidden;
        min-height: 0;
        padding: 0 4px;
    }

    .step-content h3 {
        margin: 0 0 0.25rem;
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary, #1a202c);
    }

    .step-description {
        margin: 0 0 0.75rem;
        font-size: 0.8125rem;
        color: var(--text-muted, #718096);
    }

    .loading-state, .empty-state {
        text-align: center;
        padding: 2rem;
        color: var(--text-muted, #718096);
    }
    .loading-state i, .empty-state i { font-size: 1.5rem; margin-bottom: 0.5rem; display: block; }
    .empty-state p { margin: 0.25rem 0; }

    .provider-selection {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .provider-option {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        border: 1px solid var(--border-color, #e2e8f0);
        border-radius: 0.75rem;
        cursor: pointer;
        background: var(--bg-tertiary, #f7fafc);
        transition: all 0.15s;
    }
    .provider-option:hover { border-color: #8b5cf6; background: var(--bg-hover, #f0f0f0); }
    .provider-option.selected { border-color: #8b5cf6; background: var(--accent-bg, #faf5ff); }
    .provider-option .provider-icon { font-size: 1.5rem; color: #8b5cf6; width: 2rem; text-align: center; }
    .provider-option .provider-info { flex: 1; display: flex; flex-direction: column; gap: 2px; }
    .provider-option .provider-name { font-weight: 600; color: var(--text-primary, #1a202c); }
    .provider-option .provider-type { font-size: 0.75rem; color: var(--text-muted, #718096); }
    .provider-option .selected-icon { color: #8b5cf6; }

    .step-content .search-box { margin-bottom: 0.75rem; }

    .selection-list {
        flex: 1;
        min-height: 0;
        overflow-y: auto;
        border: 1px solid var(--border-color, #e2e8f0);
        border-radius: 0.75rem;
    }

    .selection-item {
        display: flex;
        align-items: flex-start;
        gap: 0.625rem;
        padding: 0.625rem 0.875rem;
        border-bottom: 1px solid var(--border-color, #e2e8f0);
        cursor: pointer;
        transition: background 0.1s;
    }
    .selection-item:last-child { border-bottom: none; }
    .selection-item:hover { background: var(--bg-hover, #f7fafc); }
    .selection-item.selected { background: var(--accent-bg, #faf5ff); }
    .item-content { flex: 1; min-width: 0; }
    .item-name { font-weight: 500; color: var(--text-primary, #1a202c); font-size: 0.875rem; }
    .item-detail { font-size: 0.75rem; color: var(--text-muted, #718096); margin-top: 2px; }

    .publish-summary {
        background: var(--bg-tertiary, #f7fafc);
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 1rem;
    }
    .summary-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0;
    }
    .summary-item:not(:last-child) { border-bottom: 1px solid var(--border-color, #e2e8f0); }
    .summary-label { font-weight: 600; color: var(--text-muted, #718096); min-width: 100px; }
    .summary-value { color: var(--text-primary, #1a202c); display: flex; align-items: center; gap: 0.375rem; }

    .secrets-preview {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
        margin-bottom: 1rem;
    }
    .secret-badge {
        padding: 0.25rem 0.625rem;
        background: var(--bg-tertiary, #f1f5f9);
        border-radius: 0.75rem;
        font-size: 0.75rem;
        color: var(--text-secondary, #4a5568);
    }

    .warning-box {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        padding: 0.75rem 1rem;
        background: #fef3c7;
        border: 1px solid #f59e0b;
        border-radius: 0.75rem;
        color: #92400e;
        font-size: 0.875rem;
    }

    .publishing-progress, .publish-success {
        text-align: center;
        padding: 2.5rem 1.25rem;
    }
    .publishing-progress i, .publish-success i { margin-bottom: 1rem; }

    /* Dark mode */
    .theme-dark .provider-option.selected { background: rgba(139, 92, 246, 0.15); }
    .theme-dark .selection-item.selected { background: rgba(139, 92, 246, 0.1); }
    .theme-dark .warning-box { background: rgba(245, 158, 11, 0.15); border-color: rgba(245, 158, 11, 0.3); color: #fbbf24; }
</style>

@code {
    private int step = 1;
    private Dictionary<string, string> secretsDict = new();

    // Step 1: Provider
    private List<SecretsPublisherConfig> publishers = new();
    private SecretsPublisherConfig? selectedPublisher;
    private bool isLoadingPublishers = true;

    // Step 2: Repository
    private List<PublisherRepository> repositories = new();
    private PublisherRepository? selectedRepository;
    private string repoSearchFilter = "";
    private bool isLoadingRepos = false;

    // Step 3: Publish
    private bool isPublishing = false;
    private bool publishComplete = false;
    private string publishingStatus = "";

    private List<PublisherRepository> FilteredRepositories =>
        string.IsNullOrWhiteSpace(repoSearchFilter)
            ? repositories
            : repositories.Where(r => r.FullName.Contains(repoSearchFilter, StringComparison.OrdinalIgnoreCase)).ToList();

    private bool CanProceed => step switch
    {
        1 => selectedPublisher != null,
        2 => selectedRepository != null,
        3 => !isPublishing && !publishComplete,
        _ => false
    };

    protected override async Task OnInitializedAsync()
    {
        var bridge = BridgeHolder.Current;
        if (bridge == null) return;

        if (bridge.Parameters.TryGetValue("Secrets", out var secretsObj) && secretsObj is Dictionary<string, string> dict)
            secretsDict = dict;

        bridge.SubmitRequested += OnSubmitRequested;
        bridge.BackRequested += OnBackRequested;
        bridge.NextRequested += OnNextRequested;

        await LoadPublishersAsync();
        UpdateWizardState();
    }

    private async Task LoadPublishersAsync()
    {
        isLoadingPublishers = true;
        StateHasChanged();
        try
        {
            publishers = (await PublisherService.GetPublishersAsync()).ToList();
            if (publishers.Count == 1)
            {
                selectedPublisher = publishers[0];
            }
        }
        finally
        {
            isLoadingPublishers = false;
            StateHasChanged();
        }
    }

    private void SelectPublisher(SecretsPublisherConfig publisher)
    {
        selectedPublisher = publisher;
        UpdateWizardState();
        StateHasChanged();
    }

    private void SelectRepository(PublisherRepository repo)
    {
        selectedRepository = repo;
        UpdateWizardState();
        StateHasChanged();
    }

    private void UpdateWizardState()
    {
        var bridge = BridgeHolder.Current;
        if (bridge == null) return;

        bridge.SetWizardState(
            showBack: step > 1 && !isPublishing && !publishComplete,
            showNext: step < 3 && !isPublishing,
            showSubmit: step == 3 && !isPublishing && !publishComplete,
            canProceed: CanProceed,
            submitText: "Publish Secrets"
        );
    }

    private async Task OnNextRequested()
    {
        if (step == 1 && selectedPublisher != null)
        {
            step = 2;
            await LoadRepositoriesAsync();
        }
        else if (step == 2 && selectedRepository != null)
        {
            step = 3;
        }
        UpdateWizardState();
        StateHasChanged();
    }

    private Task OnBackRequested()
    {
        if (step > 1)
        {
            step--;
            UpdateWizardState();
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    private async Task OnSubmitRequested()
    {
        if (step != 3 || selectedPublisher == null || selectedRepository == null)
            return;

        isPublishing = true;
        publishingStatus = "Publishing secrets...";
        UpdateWizardState();
        StateHasChanged();

        try
        {
            await PublisherService.PublishSecretsAsync(
                selectedPublisher.Id, selectedRepository.Id, secretsDict);

            publishComplete = true;
            publishingStatus = "Done!";
            var bridge = BridgeHolder.Current;
            if (bridge != null)
                bridge.Result = true;
        }
        catch (Exception ex)
        {
            Logger.LogError($"Failed to publish secrets: {ex}");
            publishingStatus = $"Error: {ex.Message}";
        }
        finally
        {
            isPublishing = false;
            UpdateWizardState();
            StateHasChanged();
        }
    }

    private async Task LoadRepositoriesAsync()
    {
        if (selectedPublisher == null) return;
        isLoadingRepos = true;
        StateHasChanged();
        try
        {
            var instance = PublisherService.GetPublisherInstance(selectedPublisher.Id);
            if (instance != null)
                repositories = (await instance.ListRepositoriesAsync()).ToList();
        }
        finally
        {
            isLoadingRepos = false;
            StateHasChanged();
        }
    }

    private string GetPublisherIcon(string providerId) => providerId switch
    {
        "github" => "fab fa-github",
        "gitlab" => "fab fa-gitlab",
        "azure-devops" => "fab fa-microsoft",
        "gitea" => "fas fa-leaf",
        _ => "fas fa-cloud-upload-alt"
    };

    private string GetPublisherDisplayName(string providerId) =>
        PublisherFactory.GetAvailableProviders()
            .FirstOrDefault(p => p.ProviderId == providerId).DisplayName ?? providerId;

    public void Dispose()
    {
        var bridge = BridgeHolder.Current;
        if (bridge != null)
        {
            bridge.SubmitRequested -= OnSubmitRequested;
            bridge.BackRequested -= OnBackRequested;
            bridge.NextRequested -= OnNextRequested;
        }
    }
}
